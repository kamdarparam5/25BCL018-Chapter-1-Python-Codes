students = [(1, "Amit", 18), (2, "Priya", 19), (3, "Rahul", 18)]

roll = []
name = []
age = []

for s in students:
    roll.append(s[0])
    name.append(s[1])
    age.append(s[2])

print("Roll No:", roll)
print("Names:", name)
print("Age:", age)


#3
from datetime import date

d1 = (10, 3, 2023)
d2 = (25, 3, 2023)

date1 = date(d1[2], d1[1], d1[0])
date2 = date(d2[2], d2[1], d2[0])

diff = abs((date2 - date1).days)

print("Days between dates:", diff)


