#1
data = ["Amit", ("Rahul", "Rohan"), "Priya", ("Arjun",), "Sneha"]

boys = 0
girls = 0

for ele in data:
    if isinstance(ele, tuple):
        boys += len(ele)
    else:
        girls += 1

print("Number of boys:", boys)
print("Number of girls:", girls)


